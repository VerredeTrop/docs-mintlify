              "api-reference/developer-tools/remove-webhook"
            ]
          },
          {
            "group": "Webhook Events",
            "pages": [
              "api-reference/webhooks/events",
              "api-reference/webhooks/charge-events",
              "api-reference/webhooks/payment-events",
              "api-reference/webhooks/station-events",
